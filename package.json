{
  "name": "@peterjokumsen/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "prepare": "husky || true",
    "update-peer-dependencies": "node update-peer-dependencies.js",
    "mega-lint": "npx mega-linter-runner --flavor javascript",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "prep-commit": "nx format:write && nx affected --uncommitted -t lint test --parallel=5",
    "prep-push": "nx format:check && nx affected --base=origin/main -t lint test --parallel=5 --skip-nx-cache & nx affected --base=origin/main -t build --parallel=5",
    "swa-local-app-only": "swa start http://localhost:4200",
    "serve:bb-score": "nx run bb-score:serve",
    "serve:blog": "nx run blog:serve",
    "serve:bu-jo": "nx run bullet-journal:serve",
    "build:bb-score": "nx run bb-score:build",
    "build:blog": "nx run blog:build",
    "build:bu-jo": "nx run bullet-journal:build",
    "e2e:blog": "nx run blog-e2e:e2e-ci",
    "e2e:bu-jo": "nx run bullet-journal-e2e:e2e-ci",
    "e2e:blog:local": "nx run blog-e2e:e2e",
    "e2e:bu-jo:local": "nx run bullet-journal-e2e:e2e",
    "swa:blog": "concurrently --kill-others \"pnpm run serve:blog\" \"pnpm run swa-local-app-only\"",
    "swa:bu-jo": "concurrently --kill-others \"pnpm run serve:bu-jo\" \"pnpm run swa-local-app-only\"",
    "build:all": "nx run-many --target=build --all",
    "build:affected": "nx affected --target=build --base=origin/main",
    "lint:all": "nx run-many --target=lint --all",
    "lint:affected": "nx affected --target=lint --base=origin/main --parallel=5",
    "lint:uncommitted": "nx affected --target=lint --uncommitted --parallel=5",
    "test:all": "nx run-many --target=test --all",
    "test:affected": "nx affected --target=test --base=origin/main",
    "test:uncommitted": "nx affected --target=test --uncommitted"
  },
  "packageManager": "pnpm@10.6.1",
  "private": true,
  "dependencies": {
    "@angular/animations": "20.3.10",
    "@angular/cdk": "20.2.12",
    "@angular/common": "20.3.10",
    "@angular/compiler": "20.3.10",
    "@angular/core": "20.3.10",
    "@angular/forms": "20.3.10",
    "@angular/material": "20.2.12",
    "@angular/platform-browser": "20.3.10",
    "@angular/platform-browser-dynamic": "20.3.10",
    "@angular/platform-server": "20.3.10",
    "@angular/router": "20.3.10",
    "@angular/service-worker": "20.3.10",
    "@angular/ssr": "20.3.9",
    "@fortawesome/angular-fontawesome": "^1.0.0",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@ngrx/signals": "^19.2.0",
    "@nx/angular": "22.0.2",
    "express": "^4.21.2",
    "highlight.js": "^11.11.1",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "20.3.9",
    "@angular-devkit/core": "20.3.9",
    "@angular-devkit/schematics": "20.3.9",
    "@angular-eslint/eslint-plugin": "20.3.0",
    "@angular-eslint/eslint-plugin-template": "20.3.0",
    "@angular-eslint/template-parser": "20.3.0",
    "@angular/cli": "~20.3.0",
    "@angular/compiler-cli": "20.3.10",
    "@angular/language-service": "20.3.10",
    "@angular/pwa": "20.3.9",
    "@azure/static-web-apps-cli": "^2.0.4",
    "@nx/devkit": "22.0.2",
    "@nx/esbuild": "22.0.2",
    "@nx/eslint": "22.0.2",
    "@nx/eslint-plugin": "22.0.2",
    "@nx/jest": "22.0.2",
    "@nx/js": "22.0.2",
    "@nx/playwright": "22.0.2",
    "@nx/web": "22.0.2",
    "@nx/workspace": "22.0.2",
    "@playwright/test": "^1.51.0",
    "@schematics/angular": "20.3.9",
    "@swc-node/register": "~1.10.9",
    "@swc/core": "~1.11.8",
    "@swc/helpers": "~0.5.15",
    "@types/express": "5.0.0",
    "@types/jest": "29.5.14",
    "@types/node": "22.13.9",
    "@typescript-eslint/eslint-plugin": "8.40.0",
    "@typescript-eslint/parser": "8.40.0",
    "@typescript-eslint/utils": "8.40.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "esbuild": "^0.19.2",
    "eslint": "8.57.0",
    "eslint-config-prettier": "10.0.0",
    "eslint-plugin-playwright": "^1.6.2",
    "husky": "^9.1.7",
    "import-sort-style-eslint": "^6.0.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "jest-environment-node": "^29.7.0",
    "jest-preset-angular": "14.6.2",
    "jsonc-eslint-parser": "^2.4.0",
    "ng-mocks": "^14.13.2",
    "ng-packagr": "20.3.0",
    "nx": "22.0.2",
    "postcss": "^8.5.3",
    "postcss-url": "~10.1.3",
    "prettier": "^3.5.3",
    "prettier-plugin-import-sort": "^0.0.7",
    "prettier-plugin-organize-imports": "^4.1.0",
    "sharp": "^0.34.1",
    "ts-jest": "29.4.5",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  }
}
